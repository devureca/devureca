---

<div id="progress"></div>

<style>
    #progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 1px;
        background: var(--accent);
        width: 0%;
        z-index: 999;
        transition: background 0.8s ease;
    }
</style>

<script>
    const progress = document.getElementById("progress")!;

    const sections = [
        { id: "hero", theme: "", accent: "#c8ff00" },
        { id: "proyectos", theme: "theme-2", accent: "#00e5ff" },
        { id: "blog", theme: "theme-3", accent: "#bf94ff" },
        { id: "about", theme: "theme-3", accent: "#bf94ff" },
        { id: "contacto", theme: "theme-4", accent: "#ff8c42" },
    ];

    function updateScroll() {
        // Progress bar
        const scrollTop = window.scrollY;
        const docHeight =
            document.documentElement.scrollHeight - window.innerHeight;
        progress.style.width = `${(scrollTop / docHeight) * 100}%`;

        // Color theme por sección
        const mid = scrollTop + window.innerHeight * 0.45;
        let current = sections[0];
        for (const s of sections) {
            const el = document.getElementById(s.id);
            if (el && el.offsetTop <= mid) current = s;
        }
        document.body.className = current.theme;
        progress.style.background = current.accent;
    }

    window.addEventListener("scroll", updateScroll, { passive: true });
    updateScroll();
</script>
