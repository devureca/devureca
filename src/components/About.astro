---
import GitHubGraph from "./GitHubGraph.astro";
---

<section id="about">
    <div class="col">
        <div class="section-label">Sobre mí</div>

        <p class="about-text reveal">
            Basado en <strong>Huancayo, Perú</strong>. Mi trabajo une la
            complejidad de los sistemas con la apertura del open source,
            convencido de que la tecnología de alto nivel no debería tener
            barreras económicas. Cuando no programo, me pierdo entre <strong
                >historietas</strong
            > y <strong>videojuegos</strong>.
        </p>

        <div class="stack-grid reveal">
            <div class="stack-item">
                <span class="stack-label">Diseño</span>
                <span class="stack-tools">Figma · Framer</span>
            </div>
            <div class="stack-item">
                <span class="stack-label">Frontend</span>
                <span class="stack-tools">React · Astro · TypeScript</span>
            </div>
            <div class="stack-item">
                <span class="stack-label">Backend</span>
                <span class="stack-tools">Node.js · PostgreSQL</span>
            </div>
            <div class="stack-item">
                <span class="stack-label">Deploy</span>
                <span class="stack-tools">Vercel · GitHub</span>
            </div>
        </div>
    </div>
</section>

<style>
    #about {
        position: relative;
        z-index: 2;
        background: var(--bg);
        padding: 80px 0;
    }

    .section-label {
        font-size: 11px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 48px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-label::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
    }

    .about-text {
        font-size: 15px;
        color: var(--text-dim);
        line-height: 1.9;
        margin-bottom: 24px;
    }

    .about-text strong {
        color: var(--text);
        font-weight: 500;
    }

    .stack-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2px;
        margin-top: 40px;
    }

    .stack-item {
        background: var(--bg-2);
        border: 1px solid var(--border);
        padding: 16px 20px;
        display: flex;
        flex-direction: column;
        gap: 6px;
        transition: border-color 0.2s;
    }

    .stack-item:hover {
        border-color: var(--text-muted);
    }

    .stack-label {
        font-size: 10px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--accent);
        transition: color 0.8s ease;
    }

    .stack-tools {
        font-size: 13px;
        color: var(--text-dim);
        letter-spacing: 0.04em;
    }

    .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition:
            opacity 0.7s ease,
            transform 0.7s ease;
    }

    .reveal.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<script>
    document.addEventListener("astro:page-load", () => {
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting)
                        entry.target.classList.add("visible");
                });
            },
            { threshold: 0.12 },
        );

        document.querySelectorAll("#about .reveal").forEach((el, i) => {
            (el as HTMLElement).style.transitionDelay = `${i * 0.1}s`;
            observer.observe(el);
        });
    });
</script>
