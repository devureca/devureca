---
const links = [
    {
        label: "gianfranco@tudominio.com",
        href: "mailto:gianfranco@tudominio.com",
    },
    { label: "GitHub", href: "https://github.com/devureca" },
    { label: "LinkedIn", href: "https://linkedin.com/in/tuusuario" },
    { label: "Twitter / X", href: "https://x.com/tuusuario" },
];
---

<section id="contacto">
    <div class="col">
        <div class="section-label">Contacto</div>

        <h2 class="contact-heading reveal">
            ¿Tienes un proyecto<br />en <em>mente?</em>
        </h2>

        <p class="contact-sub reveal">
            Estoy abierto a proyectos freelance, colaboraciones y conversaciones
            interesantes. Si algo te resuena, escríbeme.
        </p>

        <div class="contact-links reveal">
            {
                links.map((link) => (
                    <a
                        href={link.href}
                        class="contact-link"
                        target="_blank"
                        rel="noopener"
                    >
                        <span>{link.label}</span>
                        <span class="arrow">↗</span>
                    </a>
                ))
            }
        </div>
    </div>
</section>

<style>
    #contacto {
        position: relative;
        z-index: 2;
        background: var(--bg);
        padding: 80px 0 120px;
    }

    .section-label {
        font-size: 11px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 48px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-label::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
    }

    .contact-heading {
        font-size: clamp(24px, 3.5vw, 36px);
        line-height: 1.3;
        margin-bottom: 24px;
        font-weight: 400;
        letter-spacing: -0.01em;
    }

    .contact-heading em {
        font-style: normal;
        color: var(--accent);
        transition: color 0.8s ease;
    }

    .contact-sub {
        color: var(--text-dim);
        font-size: 14px;
        margin-bottom: 40px;
        max-width: 420px;
        line-height: 1.8;
    }

    .contact-links {
        display: flex;
        flex-direction: column;
    }

    .contact-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 0;
        border-bottom: 1px solid var(--border);
        text-decoration: none;
        color: var(--text);
        font-size: 13px;
        letter-spacing: 0.06em;
        transition: color 0.2s;
    }

    .contact-link:first-child {
        border-top: 1px solid var(--border);
    }

    .contact-link:hover {
        color: var(--accent);
    }

    .contact-link:hover .arrow {
        transform: translate(4px, -4px);
    }

    .arrow {
        font-size: 16px;
        transition: transform 0.2s ease;
    }

    /* Reveal */
    .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition:
            opacity 0.7s ease,
            transform 0.7s ease;
    }

    .reveal.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<script>
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) entry.target.classList.add("visible");
            });
        },
        { threshold: 0.12 },
    );

    document.querySelectorAll("#contacto .reveal").forEach((el, i) => {
        (el as HTMLElement).style.transitionDelay = `${i * 0.1}s`;
        observer.observe(el);
    });
</script>
