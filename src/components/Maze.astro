<div class="maze-wrap" id="mazeWrap" title="Click para nuevo patrón">
    <canvas id="mazeCanvas" width="96" height="96"></canvas>
</div>

<style>
    .maze-wrap {
        width: 96px;
        height: 96px;
        background: var(--bg-2);
        border: none;
        margin-bottom: 32px;
        cursor: pointer;
        overflow: hidden;
    }

    .maze-wrap:hover {
        border-color: var(--border);
    }

    canvas {
        display: block;
    }
</style>

<script>
    const canvas = document.getElementById("mazeCanvas") as HTMLCanvasElement;
    const wrap = document.getElementById("mazeWrap");
    const ctx = canvas.getContext("2d")!;

    const SIZE = 96;
    const CELL = 12;

    type LineType = "diagonalDown" | "diagonalUp";

    function drawLine(x: number, y: number, type: LineType) {
        ctx.beginPath();
        if (type === "diagonalDown") {
            ctx.moveTo(x, y);
            ctx.lineTo(x + CELL, y + CELL);
        } else {
            ctx.moveTo(x, y + CELL);
            ctx.lineTo(x + CELL, y);
        }
        ctx.stroke();
    }

    function generate() {
        ctx.clearRect(0, 0, SIZE, SIZE);

        // Fondo
        ctx.fillStyle = "#0d0d0d";
        ctx.fillRect(0, 0, SIZE, SIZE);

        // Líneas diagonales
        ctx.strokeStyle = "rgba(255,255,255,0.75)";
        ctx.lineWidth = 0.6;
        ctx.lineCap = "square";

        for (let x = 0; x < SIZE; x += CELL) {
            for (let y = 0; y < SIZE; y += CELL) {
                const type: LineType =
                    Math.random() > 0.5 ? "diagonalDown" : "diagonalUp";
                drawLine(x, y, type);
            }
        }
    }

    wrap?.addEventListener("click", () => {
        canvas.style.opacity = "0";
        canvas.style.transition = "opacity 0.15s ease";
        setTimeout(() => {
            generate();
            canvas.style.opacity = "1";
        }, 150);
    });

    generate();
</script>
