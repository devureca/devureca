---
const projects = [
    {
        slug: "qollqastore",
        name: "QollqaStore",
        year: "2026",
        tags: ["Astro", "Google Sheets", "Open Source"],
        desc: "Catálogo web gratuito para emprendedores que utiliza Google Sheets como base de datos.",
        image: "https://res.cloudinary.com/dpabb0ryo/image/upload/q_auto/f_auto/v1775147595/qollqastore.com_jukicx.png",
    },
    {
        slug: "devureca-portfolio",
        name: "Devureca",
        year: "2026",
        tags: ["Astro", "TypeScript", "Design"],
        desc: "Portafolio profesional con estética de planos técnicos y branding minimalista.",
        image: "/images/devureca.jpg",
    },
    {
        slug: "price-charting-peru",
        name: "Price Charting PE",
        year: "2024",
        tags: ["Next.js", "Scraping", "Games"],
        desc: "Herramienta de tracking de precios para el mercado de videojuegos en Perú.",
        image: "/images/pricecharting.jpg",
    },
];
---

<section class="projects-section" id="projects-section">
    <div class="projects-lines">
        <svg id="projects-blueprint-svg"></svg>
    </div>

    <div class="projects-container" id="projects-container">
        <div class="section-header" id="projects-header-box">
            <span class="section-label">Proyectos seleccionados</span>
        </div>

        <div class="carousel-outer" id="carousel-main-box">
            <div class="carousel-track-wrap" id="carouselWrap">
                <div class="carousel-track" id="carouselTrack">
                    {
                        projects.map((p) => (
                            <div class="project-card">
                                <div class="card-img-wrapper">
                                    <img
                                        src={p.image}
                                        alt={p.name}
                                        class="project-image"
                                    />

                                    <div class="card-overlay">
                                        <div class="card-overlay-top">
                                            <div class="card-tags">
                                                {p.tags.map((t) => (
                                                    <span class="card-tag">
                                                        {t}
                                                    </span>
                                                ))}
                                            </div>
                                            <span class="card-arrow">↗</span>
                                        </div>
                                        <div class="card-overlay-bottom">
                                            <div class="card-title">
                                                {p.name}
                                            </div>
                                            <div class="card-desc">
                                                {p.desc}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-foot">
                                    <span class="card-name">{p.name}</span>
                                    <span class="card-year">{p.year}</span>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>

        <div class="carousel-controls" id="projects-footer-box">
            <div class="carousel-nav">
                <button class="carousel-btn" id="btnPrev">←</button>
                <button class="carousel-btn" id="btnNext">→</button>
            </div>
        </div>
    </div>
</section>

<style>
    .projects-section {
        position: relative;
        width: 100%;
        display: flex;
        justify-content: center;
        background: transparent;
        margin-top: -1px;
    }

    .projects-lines {
        position: absolute;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        z-index: 1;
    }

    #projects-blueprint-svg {
        width: 100%;
        height: 100%;
        display: block;
    }

    .projects-container {
        position: relative;
        width: min(48rem, calc(100% - 2rem));
        display: flex;
        flex-direction: column;
        z-index: 2;
    }

    .section-header {
        padding: 1.5rem;
    }

    .section-label {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-primary);
    }

    .carousel-outer {
        width: 100%;
        overflow: hidden;
        padding: 2rem 1.5rem;
    }

    .carousel-track-wrap {
        cursor: grab;
    }

    .carousel-track-wrap:active {
        cursor: grabbing;
    }

    .carousel-track {
        display: flex;
        gap: 24px;
        will-change: transform;
        user-select: none;
    }

    .project-card {
        width: 380px;
        flex-shrink: 0;
    }

    .card-img-wrapper {
        width: 100%;
        aspect-ratio: 16/9;
        border: 1px solid var(--border-color);
        position: relative;
        overflow: hidden;
        background: var(--bg-surface);
        display: flex;
        align-items: flex-start;
    }

    .project-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition:
            opacity 0.4s ease,
            transform 0.6s ease;
        display: block;
        opacity: 1;
    }

    .project-card:hover .project-image {
        opacity: 0;
        transform: scale(1.03);
    }

    .card-overlay {
        position: absolute;
        inset: 0;
        background: var(--bg-surface);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 24px;
        opacity: 0;
        visibility: hidden;
        transition:
            opacity 0.4s ease,
            visibility 0.4s ease;
        z-index: 2;
    }

    .project-card:hover .card-overlay {
        opacity: 1;
        visibility: visible;
    }

    .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .card-tag {
        font-family: var(--font-mono);
        font-size: 9px;
        padding: 3px 7px;
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        letter-spacing: 0.05em;
    }

    .card-arrow {
        color: var(--text-primary);
        font-size: 14px;
    }

    .card-title {
        font-family: var(--font-sans);
        font-size: 1.4rem;
        font-weight: 500;
        color: var(--text-primary);
        margin-bottom: 7px;
        letter-spacing: -0.01em;
    }

    .card-desc {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--text-muted);
        line-height: 1.6;
        font-weight: 300;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-foot {
        display: flex;
        justify-content: space-between;
        margin-top: 12px;
        font-family: var(--font-mono);
        font-size: 12px;
        padding: 0 2px;
    }

    .card-name {
        color: var(--text-primary);
    }

    .card-year {
        color: var(--text-muted);
        opacity: 0.6;
    }

    .carousel-controls {
        padding: 1.5rem;
    }

    .carousel-nav {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .carousel-btn {
        background: transparent;
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        padding: 5px 15px;
        cursor: pointer;
        font-family: var(--font-mono);
        transition: all 0.2s ease;
    }

    .carousel-btn:hover {
        background: var(--text-primary);
        color: var(--bg-body);
        border-color: var(--text-primary);
    }
</style>

<script>
    function initCarousel() {
        const track = document.getElementById("carouselTrack") as HTMLElement;
        const wrap = document.getElementById("carouselWrap") as HTMLElement;
        const btnPrev = document.getElementById("btnPrev") as HTMLElement;
        const btnNext = document.getElementById("btnNext") as HTMLElement;
        const cards = document.querySelectorAll(".project-card");

        if (!track || !wrap || !cards.length) return;

        let currentIndex = 0;
        let startX = 0;
        let isDragging = false;

        function getMoveDistance(): number {
            return (cards[0] as HTMLElement).clientWidth + 24;
        }

        function goTo(index: number) {
            currentIndex = Math.max(0, Math.min(index, cards.length - 1));
            const offset = -(currentIndex * getMoveDistance());
            track.style.transition =
                "transform 0.5s cubic-bezier(0.19, 1, 0.22, 1)";
            track.style.transform = `translateX(${offset}px)`;
        }

        btnNext?.addEventListener("click", () => goTo(currentIndex + 1));
        btnPrev?.addEventListener("click", () => goTo(currentIndex - 1));

        wrap.addEventListener("mousedown", (e: MouseEvent) => {
            isDragging = true;
            startX = e.clientX;
            track.style.transition = "none";
        });

        window.addEventListener("mousemove", (e: MouseEvent) => {
            if (!isDragging) return;
            const delta = e.clientX - startX;
            const baseOffset = -(currentIndex * getMoveDistance());
            track.style.transform = `translateX(${baseOffset + delta}px)`;
        });

        window.addEventListener("mouseup", (e: MouseEvent) => {
            if (!isDragging) return;
            isDragging = false;
            const delta = e.clientX - startX;
            if (delta < -100) goTo(currentIndex + 1);
            else if (delta > 100) goTo(currentIndex - 1);
            else goTo(currentIndex);
        });
    }

    function drawProjectsBlueprint() {
        const section = document.getElementById("projects-section");
        const container = document.getElementById("projects-container");
        const header = document.getElementById("projects-header-box");
        const main = document.getElementById("carousel-main-box");
        const svg = document.getElementById(
            "projects-blueprint-svg",
        ) as unknown as SVGSVGElement;

        if (!section || !container || !header || !main || !svg) return;

        const W = section.offsetWidth;
        const H = section.offsetHeight;
        const nL = container.offsetLeft;
        const nR = container.offsetLeft + container.offsetWidth;

        const t1 = 0;
        const t2 = header.offsetHeight;
        const t3 = header.offsetHeight + main.offsetHeight;
        const t4 = H;

        const isDark = !document.documentElement.classList.contains("light");
        const stroke = isDark
            ? "rgba(255, 255, 255, 0.1)"
            : "rgba(0, 0, 0, 0.08)";
        const dotFill = isDark
            ? "rgba(255, 255, 255, 0.3)"
            : "rgba(0, 0, 0, 0.2)";

        let markup = "";
        [t1, t2, t3, t4].forEach((y) => {
            markup += `<line x1="0" y1="${y}" x2="${W}" y2="${y}" stroke="${stroke}" stroke-width="0.8"/>`;
        });

        [nL, nR].forEach((x) => {
            markup += `<line x1="${x}" y1="0" x2="${x}" y2="${H}" stroke="${stroke}" stroke-width="0.8"/>`;
        });

        [t1, t2, t3, t4].forEach((y) => {
            [nL, nR].forEach((x) => {
                markup += `<circle cx="${x}" cy="${y}" r="2" fill="${dotFill}"/>`;
            });
        });

        svg.setAttribute("viewBox", `0 0 ${W} ${H}`);
        svg.innerHTML = markup;
    }

    document.addEventListener("astro:page-load", () => {
        initCarousel();
        drawProjectsBlueprint();
    });

    window.addEventListener("resize", drawProjectsBlueprint);
    document.documentElement.addEventListener(
        "themechange",
        drawProjectsBlueprint,
    );
</script>
