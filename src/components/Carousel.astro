---
const projects = [
    {
        slug: "proyecto-uno",
        name: "Proyecto Uno",
        year: "2024",
        tags: ["React", "TypeScript", "Node.js"],
        desc: "Plataforma SaaS para equipos de diseño. Gestión de assets, handoff y documentación en un solo lugar.",
    },
    {
        slug: "proyecto-dos",
        name: "Proyecto Dos",
        year: "2024",
        tags: ["Mobile", "Swift", "Figma"],
        desc: "App móvil para seguimiento de hábitos. Diseño y desarrollo completo desde cero.",
    },
    {
        slug: "proyecto-tres",
        name: "Proyecto Tres",
        year: "2023",
        tags: ["Dashboard", "D3.js", "Design System"],
        desc: "Dashboard de analytics con visualizaciones complejas y sistema de diseño con 80+ componentes.",
    },
    {
        slug: "proyecto-cuatro",
        name: "Proyecto Cuatro",
        year: "2023",
        tags: ["Astro", "Tailwind", "CMS"],
        desc: "Sitio editorial con CMS headless, optimizado para velocidad y SEO. 100/100 en Lighthouse.",
    },
    {
        slug: "proyecto-cinco",
        name: "Proyecto Cinco",
        year: "2022",
        tags: ["Next.js", "Postgres", "Auth"],
        desc: "Plataforma de comunidad con sistema de auth propio, perfiles y contenido generado por usuarios.",
    },
];
---

<section id="proyectos">
    <div class="col">
        <div class="section-label">Proyectos seleccionados</div>
    </div>

    <div class="carousel-outer">
        <div class="carousel-track-wrap" id="carouselWrap">
            <div class="carousel-track" id="carouselTrack">
                {
                    projects.map((p) => (
                        <div class="project-card">
                            <div class="card-img">
                                <div class="card-overlay">
                                    <div class="card-overlay-top">
                                        <div class="card-tags">
                                            {p.tags.map((t) => (
                                                <span class="card-tag">
                                                    {t}
                                                </span>
                                            ))}
                                        </div>
                                        <span class="card-arrow">↗</span>
                                    </div>
                                    <div class="card-overlay-bottom">
                                        <div class="card-title">{p.name}</div>
                                        <div class="card-desc">{p.desc}</div>
                                    </div>
                                </div>
                            </div>
                            <div class="card-foot">
                                <a
                                    href={`/proyectos/${p.slug}`}
                                    class="card-name"
                                >
                                    {p.name}
                                </a>
                                <span class="card-year">{p.year}</span>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>

        <div class="carousel-nav">
            <button class="carousel-btn" id="btnPrev">←</button>
            <button class="carousel-btn" id="btnNext">→</button>
            <div class="carousel-dots" id="carouselDots"></div>
        </div>
    </div>
</section>

<style>
    #proyectos {
        position: relative;
        z-index: 2;
        background: var(--bg);
        padding: 80px 0;
    }

    .section-label {
        font-size: 11px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 32px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-label::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
    }

    .carousel-outer {
        width: 100vw;
        left: 50%;
        position: relative;
        transform: translateX(-50%);
        overflow: hidden;
    }

    .carousel-track-wrap {
        overflow: hidden;
        cursor: grab;
        padding: 8px 0 16px;
    }

    .carousel-track-wrap:active {
        cursor: grabbing;
    }

    .carousel-track {
        display: flex;
        gap: 16px;
        padding: 0 max(24px, calc((100vw - 660px) / 2));
        width: max-content;
        will-change: transform;
        user-select: none;
    }

    .project-card {
        width: 440px;
        flex-shrink: 0;
        cursor: pointer;
        text-decoration: none;
    }

    .card-img {
        width: 100%;
        aspect-ratio: 16/10;
        background: var(--bg-2);
        border: 1px solid var(--border);
        position: relative;
        overflow: hidden;
    }

    .card-overlay {
        position: absolute;
        inset: 0;
        background: var(--bg);
        border: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 24px;
        opacity: 0;
        transform: translateY(6px);
        transition:
            opacity 0.3s ease,
            transform 0.3s ease;
    }

    .project-card:hover .card-overlay {
        opacity: 1;
        transform: translateY(0);
    }

    .card-overlay-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .card-tag {
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 4px 8px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--text-dim);
    }

    .card-arrow {
        font-size: 18px;
        color: var(--accent);
        transition: transform 0.2s ease;
    }

    .project-card:hover .card-arrow {
        transform: translate(3px, -3px);
    }

    .card-title {
        font-size: 22px;
        color: var(--text);
        margin-bottom: 8px;
        letter-spacing: 0.01em;
    }

    .card-desc {
        font-size: 12px;
        color: var(--text-dim);
        line-height: 1.7;
    }

    .card-foot {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-top: 14px;
        padding: 0 2px;
    }

    .card-name {
        font-size: 13px;
        color: var(--text-dim);
        letter-spacing: 0.04em;
        text-decoration: none;
        transition: color 0.2s;
    }

    .card-name:hover {
        color: var(--text);
    }

    .card-year {
        font-size: 11px;
        color: var(--border);
        letter-spacing: 0.1em;
    }

    .carousel-nav {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 24px;
        padding: 0 max(24px, calc((100vw - 660px) / 2));
    }

    .carousel-btn {
        width: 36px;
        height: 36px;
        border: 1px solid var(--border);
        background: transparent;
        color: var(--text-muted);
        font-size: 16px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition:
            border-color 0.2s,
            color 0.2s;
    }

    .carousel-btn:hover {
        border-color: var(--text-muted);
        color: var(--text);
    }

    .carousel-dots {
        display: flex;
        gap: 6px;
        margin-left: 8px;
    }

    .carousel-dot {
        width: 4px;
        height: 4px;
        background: var(--border);
        border-radius: 50%;
        cursor: pointer;
        transition:
            background 0.3s,
            transform 0.3s;
    }

    .carousel-dot.active {
        background: var(--accent);
        transform: scale(1.4);
    }
</style>

<script>
    const track = document.getElementById("carouselTrack")!;
    const wrap = document.getElementById("carouselWrap")!;
    const btnPrev = document.getElementById("btnPrev")!;
    const btnNext = document.getElementById("btnNext")!;
    const dotsContainer = document.getElementById("carouselDots")!;
    const cards = track.querySelectorAll<HTMLElement>(".project-card");

    let currentIndex = 0;
    let offset = 0;
    let dragDelta = 0;

    // Dots
    cards.forEach((_, i) => {
        const dot = document.createElement("div");
        dot.className = "carousel-dot" + (i === 0 ? " active" : "");
        dot.addEventListener("click", () => goTo(i));
        dotsContainer.appendChild(dot);
    });

    function getCardWidth() {
        return cards[0].getBoundingClientRect().width + 16;
    }

    function goTo(index: number) {
        currentIndex = Math.max(0, Math.min(index, cards.length - 1));
        offset = -(currentIndex * getCardWidth());
        track.style.transition =
            "transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94)";
        track.style.transform = `translateX(${offset}px)`;
        dotsContainer.querySelectorAll(".carousel-dot").forEach((d, i) => {
            d.classList.toggle("active", i === currentIndex);
        });
    }

    btnNext.addEventListener("click", () => goTo(currentIndex + 1));
    btnPrev.addEventListener("click", () => goTo(currentIndex - 1));

    /// Drag
    let isDragging = false;
    let hasMoved = false;
    let startX = 0;
    let startOffset = 0;

    wrap.addEventListener("mousedown", (e) => {
        isDragging = true;
        hasMoved = false;
        startX = e.clientX;
        startOffset = offset;
        dragDelta = 0;
        track.style.transition = "none";
    });

    window.addEventListener("mousemove", (e) => {
        if (!isDragging) return;
        dragDelta = e.clientX - startX;
        if (Math.abs(dragDelta) > 4) hasMoved = true;
        track.style.transform = `translateX(${startOffset + dragDelta}px)`;
    });

    window.addEventListener("mouseup", () => {
        if (!isDragging) return;
        isDragging = false;
        const threshold = getCardWidth() * 0.2;
        if (dragDelta < -threshold) goTo(currentIndex + 1);
        else if (dragDelta > threshold) goTo(currentIndex - 1);
        else goTo(currentIndex);
    });

    // Evitar navegación si hubo drag
    cards.forEach((card) => {
        card.addEventListener("click", (e) => {
            if (hasMoved) {
                e.preventDefault();
                hasMoved = false;
            }
        });
    });

    // Touch
    wrap.addEventListener("touchstart", (e) => {
        startX = e.touches[0].clientX;
        startOffset = offset;
        dragDelta = 0;
        track.style.transition = "none";
    });

    wrap.addEventListener("touchmove", (e) => {
        dragDelta = e.touches[0].clientX - startX;
        track.style.transform = `translateX(${startOffset + dragDelta}px)`;
    });

    wrap.addEventListener("touchend", () => {
        if (dragDelta < -60) goTo(currentIndex + 1);
        else if (dragDelta > 60) goTo(currentIndex - 1);
        else goTo(currentIndex);
    });

    // Evitar navegación al hacer drag
    cards.forEach((card) => {
        card.addEventListener("click", (e) => {
            if (Math.abs(dragDelta) > 8) e.preventDefault();
        });
    });

    goTo(0);
</script>
