<div class="github-graph reveal" id="githubGraph">
    <!-- <div class="graph-header">
        <span class="graph-label">Actividad en GitHub</span>
        <a
            href="https://github.com/devureca"
            target="_blank"
            rel="noopener"
            class="graph-link"
        >
            @devureca ↗
        </a>
    </div> -->
    <div class="graph-container" id="graphContainer">
        <div class="graph-loading">Cargando...</div>
    </div>
</div>

<style>
    .github-graph {
        /* margin-top: 40px; */
        margin-bottom: 40px;
    }

    .graph-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .graph-label {
        font-size: 10px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .graph-link {
        font-size: 11px;
        color: var(--text-muted);
        text-decoration: none;
        letter-spacing: 0.06em;
        transition: color 0.2s;
    }

    .graph-link:hover {
        color: var(--accent);
    }

    .graph-container {
        width: 100%;
        overflow-x: auto;
        scrollbar-width: none; /* Firefox */
    }

    .graph-container::-webkit-scrollbar {
        display: none; /* Chrome/Safari */
    }

    .graph-loading {
        font-size: 11px;
        color: var(--text-muted);
        letter-spacing: 0.06em;
    }

    :global(.graph-grid) {
        display: flex;
        gap: 3px;
        width: max-content;
    }

    :global(.graph-week) {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    :global(.graph-day) {
        width: 10px;
        height: 10px;
        background: var(--bg-2);
        border-radius: 2px;
        cursor: default;
        position: relative;
    }

    :global(.graph-day[data-level="1"]) {
        background: rgba(233, 84, 32, 0.25);
    }
    :global(.graph-day[data-level="2"]) {
        background: rgba(233, 84, 32, 0.5);
    }
    :global(.graph-day[data-level="3"]) {
        background: rgba(233, 84, 32, 0.75);
    }
    :global(.graph-day[data-level="4"]) {
        background: rgba(233, 84, 32, 1);
    }

    .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition:
            opacity 0.7s ease,
            transform 0.7s ease;
    }

    .reveal.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<script>
    document.addEventListener("astro:page-load", async () => {
        const container = document.getElementById("graphContainer");
        if (!container) return;

        try {
            const res = await fetch(
                "https://github-contributions-api.jogruber.de/v4/devureca?y=2026",
            );
            const data = await res.json();

            const contributions = data.contributions as {
                date: string;
                count: number;
                level: number;
            }[];

            const grid = document.createElement("div");
            grid.className = "graph-grid";

            let weekEl = document.createElement("div");
            weekEl.className = "graph-week";

            contributions.forEach((day, i) => {
                const dayEl = document.createElement("div");
                dayEl.className = "graph-day";
                dayEl.dataset.level = String(day.level);
                dayEl.dataset.tooltip = `${day.count} contribuciones — ${day.date}`;
                weekEl.appendChild(dayEl);

                if ((i + 1) % 7 === 0) {
                    grid.appendChild(weekEl);
                    weekEl = document.createElement("div");
                    weekEl.className = "graph-week";
                }
            });

            if (weekEl.children.length > 0) grid.appendChild(weekEl);

            container.innerHTML = "";
            container.appendChild(grid);
        } catch (e) {
            container.innerHTML =
                '<div class="graph-loading">No se pudo cargar la actividad.</div>';
        }

        // Tooltip con JS
        const tooltip = document.createElement("div");
        tooltip.id = "graphTooltip";
        tooltip.style.cssText = `
        position: fixed;
        display: none;
        background: var(--bg-2);
        border: 1px solid var(--border);
        color: var(--text);
        font-size: 10px;
        font-family: 'DM Mono', monospace;
        padding: 4px 8px;
        white-space: nowrap;
        letter-spacing: 0.04em;
        pointer-events: none;
        z-index: 1000;
      `;
        document.body.appendChild(tooltip);

        container.addEventListener("mouseover", (e) => {
            const target = e.target as HTMLElement;
            if (!target.classList.contains("graph-day")) return;

            const text = target.dataset.tooltip || "";
            tooltip.textContent = text;
            tooltip.style.display = "block";
        });

        container.addEventListener("mousemove", (e) => {
            const target = e.target as HTMLElement;
            if (!target.classList.contains("graph-day")) return;

            const rect = target.getBoundingClientRect();
            const tRect = tooltip.getBoundingClientRect();
            const viewH = window.innerHeight;

            // Mostrar arriba o abajo según espacio disponible
            if (rect.top > tRect.height + 16) {
                tooltip.style.top = `${rect.top - tRect.height - 6}px`;
            } else {
                tooltip.style.top = `${rect.bottom + 6}px`;
            }

            tooltip.style.left = `${rect.left + rect.width / 2 - tRect.width / 2}px`;
        });

        container.addEventListener("mouseout", (e) => {
            const target = e.target as HTMLElement;
            if (!target.classList.contains("graph-day")) return;
            tooltip.style.display = "none";
        });

        // Reveal observer
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting)
                        entry.target.classList.add("visible");
                });
            },
            { threshold: 0.12 },
        );

        document.querySelectorAll("#githubGraph.reveal").forEach((el) => {
            observer.observe(el);
        });
    });
</script>
