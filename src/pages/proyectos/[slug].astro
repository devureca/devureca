---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
    const projects = await getCollection("proyectos");
    return projects.map((project: CollectionEntry<"proyectos">) => ({
        params: { slug: project.slug },
        props: { project },
    }));
}

const { project } = Astro.props as { project: CollectionEntry<"proyectos"> };
const { Content } = await render(project);
---

<Layout title={`${project.data.name} — Gianfranco Ureta`}>
    <Nav />

    <main>
        <div class="col">
            <a href="/" class="back">← Volver</a>

            <div class="project-header">
                <div class="project-tags">
                    {
                        project.data.tags.map((t: string) => (
                            <span class="tag">{t}</span>
                        ))
                    }
                </div>
                <h1>{project.data.name}</h1>
                <p class="project-desc">{project.data.desc}</p>
                <span class="project-year">{project.data.year}</span>
            </div>

            <div class="project-image"></div>

            <div class="project-content">
                <Content />
            </div>
        </div>
    </main>

    <Footer />
</Layout>

<style>
    main {
        position: relative;
        z-index: 2;
        background: var(--bg);
        min-height: 100vh;
        padding: 120px 0 80px;
    }

    .back {
        display: inline-block;
        font-size: 12px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted);
        text-decoration: none;
        margin-bottom: 48px;
        transition: color 0.2s;
    }

    .back:hover {
        color: var(--text);
    }

    .project-header {
        margin-bottom: 48px;
    }

    .project-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 24px;
    }

    .tag {
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 4px 10px;
        border: 1px solid var(--border);
        color: var(--text-muted);
    }

    h1 {
        font-size: clamp(28px, 5vw, 48px);
        font-weight: 400;
        letter-spacing: -0.01em;
        line-height: 1.2;
        margin-bottom: 16px;
        color: var(--text);
    }

    .project-desc {
        font-size: 16px;
        color: var(--text-dim);
        line-height: 1.8;
        margin-bottom: 12px;
    }

    .project-year {
        font-size: 11px;
        letter-spacing: 0.1em;
        color: var(--text-muted);
    }

    .project-image {
        width: 100%;
        aspect-ratio: 16/9;
        background: var(--bg-2);
        border: 1px solid var(--border);
        margin: 40px 0 48px;
    }

    .project-content {
        font-size: 15px;
        color: var(--text-dim);
        line-height: 1.9;
        max-width: 600px;
    }

    .project-content :global(h2) {
        font-size: 20px;
        font-weight: 400;
        color: var(--text);
        margin: 40px 0 16px;
    }

    .project-content :global(p) {
        margin-bottom: 20px;
    }

    .project-content :global(strong) {
        color: var(--text);
        font-weight: 500;
    }
</style>
